# Optional local overrides for SuccessFactors Instance Explorer.
# Copy to .env only when you need to change the defaults.

# API/static server port. Default: 5174
PORT=5174

# Bind address for the API server. Default: 127.0.0.1 (loopback only).
# Only change this if you know you want to expose the server to other devices on
# your network — the app has no auth, so set this to 0.0.0.0 only on a network
# you trust.
# SUCCESSFACTORS_INSTANCE_EXPLORER_HOST=127.0.0.1

# Project workspaces created by the web ingest flow.
# Default: <repo>/projects (gitignored).
# SUCCESSFACTORS_INSTANCE_EXPLORER_PROJECTS_DIR=/absolute/path/to/projects

# Skip the UI production build before starting the server during local iteration.
# SUCCESSFACTORS_INSTANCE_EXPLORER_SKIP_UI_BUILD=1
